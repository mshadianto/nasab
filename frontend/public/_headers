# Cloudflare Pages _headers — applies to all responses from nasab.biz.id
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

# ── Hashed Vite assets — immutable for 1 year ──
# Filenames contain content hash (e.g. index-DGUMU50G.js), so any change
# produces a new filename. Safe to cache aggressively forever.
# `! Cache-Control` removes Pages' default `public, max-age=0, must-revalidate`
# header before we set our own — otherwise the values get appended into one
# conflicting list and CDN downgrades the cache.
/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

*.woff2
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

*.woff
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

# ── Service worker & manifest — must always revalidate ──
# SW update detection relies on the browser refetching sw.js. If this gets
# cached for any meaningful TTL, SW updates can take days to roll out.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

# ── Root SPA shell + everything else ──
# index.html must revalidate so users always boot off the bundle that
# matches the deployed asset hashes. Security headers applied here cascade
# down to /* via Pages header inheritance.
/*
  Cache-Control: public, max-age=0, must-revalidate
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org; connect-src 'self' https://nasab-api.sopian-hadianto.workers.dev https://api.anthropic.com https://api.groq.com https://generativelanguage.googleapis.com https://nominatim.openstreetmap.org https://*.basemaps.cartocdn.com; worker-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
